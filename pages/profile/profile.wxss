/* pages/profile/profile.wxss */
.profile-page {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.input-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input-field {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* BMI显示区域样式 */
.bmi-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.bmi-header {
  margin-bottom: 20rpx;
}

.bmi-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.bmi-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.bmi-value {
  display: flex;
  align-items: baseline;
}

.bmi-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #07c160;
  margin-right: 10rpx;
}

.bmi-unit {
  font-size: 24rpx;
  color: #999;
}

.bmi-status {
  display: flex;
  align-items: center;
}

.status-text {
  font-size: 28rpx;
  color: #666;
  margin-right: 15rpx;
}

.status-indicator {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.status-indicator.underweight {
  background: #ff9500; /* 偏瘦 - 橙色 */
}

.status-indicator.normal {
  background: #07c160; /* 正常 - 绿色 */
}

.status-indicator.overweight {
  background: #ff6b35; /* 超重 - 橙红色 */
}

.status-indicator.obese {
  background: #ff3b30; /* 肥胖 - 红色 */
}

.bmi-tip {
  padding: 15rpx;
  background: rgba(7, 193, 96, 0.05);
  border-radius: 8rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 健康目标选项样式 */
.goal-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.goal-item {
  display: flex;
  align-items: center;
  padding: 25rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.goal-item.selected {
  border-color: #07c160;
  background: rgba(7, 193, 96, 0.05);
}

