  /* pages/index/index.wxss */
  .container {
    padding: 40rpx;
    min-height: 100vh;
    background: #f5f5f5;
  }

  .header {
    margin-bottom: 60rpx;
  }

  .greeting {
    display: block;
    font-size: 44rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 10rpx;
  }

  .subtitle {
    display: block;
    font-size: 28rpx;
    color: #666;
  }

  .function-cards {
    display: flex;
    flex-direction: column;
    gap: 30rpx;
  }

  .card {
    display: flex;
    align-items: center;
    padding: 40rpx;
    background: white;
    border-radius: 20rpx;
    box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  }

  .card-icon {
    font-size: 60rpx;
    margin-right: 30rpx;
  }

  .card-content {
    flex: 1;
  }

  .card-title {
    display: block;
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 8rpx;
  }

  .card-desc {
    display: block;
    font-size: 24rpx;
    color: #666;
  }

  .card-arrow {
    font-size: 36rpx;
    color: #999;
  }

  .tip {
    margin-top: 40rpx;
    text-align: center;
    font-size: 24rpx;
    color: #999;
    padding: 20rpx;
    background: rgba(7, 193, 96, 0.1);
    border-radius: 12rpx;
  }