.container {
  padding: 100rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 60rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 80rpx;
  color: #333;
}

.input-section {
  width: 100%;
}

.name-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #ddd;
  border-radius: 16rpx;
  padding: 0 20rpx;
  margin-bottom: 40rpx;
  font-size: 28rpx;
}

.enter-btn {
  width: 100%;
  background-color: #28a745;
}