/* pages/analysis/analysis.wxss */
.container {
  padding: 40rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

/* ── 上传区域 ── */
.upload-section {
  text-align: center;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.image-upload {
  width: 300rpx;
  height: 300rpx;
  border: 2rpx dashed #ddd;
  border-radius: 16rpx;
  margin: 0 auto 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: white;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.upload-placeholder {
  text-align: center;
}

.upload-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

.upload-btn {
  width: 200rpx;
  background: #07c160;
  color: white;
}

/* ── 结果公共 ── */
.result-section {
  margin-top: 40rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* ── YOLO 营养卡片 ── */
.result-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
}

.food-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.food-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.confidence {
  font-size: 22rpx;
  color: #07c160;
  background: #e8f8ee;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.nutrition-grid {
  display: flex;
  justify-content: space-around;
}

.nutrition-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.nutrition-item .num {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.nutrition-item .unit {
  font-size: 20rpx;
  color: #999;
  margin-top: 2rpx;
}

.nutrition-item .label {
  font-size: 22rpx;
  color: #666;
  margin-top: 6rpx;
}

/* ── DeepSeek 百科卡片 ── */
.deepseek-section {
  margin-top: 30rpx;
}

.deepseek-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
}

.ds-block {
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.ds-block:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.ds-label {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #444;
  margin-bottom: 10rpx;
}

.ds-text {
  display: block;
  font-size: 24rpx;
  color: #555;
  line-height: 1.7;
}

.ds-method {
  display: flex;
  margin-bottom: 6rpx;
}

.ds-index {
  font-size: 24rpx;
  color: #07c160;
  font-weight: bold;
  margin-right: 8rpx;
}

.ds-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #e67e22;
  background: #fdf2e9;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.ds-search {
  color: #8e44ad;
  background: #f4ecf7;
  padding: 16rpx;
  border-radius: 12rpx;
  line-height: 1.7;
}

/* ── 降级提示 ── */
.degrade-tip {
  margin-top: 30rpx;
  background: #fef9e7;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.degrade-text {
  font-size: 22rpx;
  color: #b7950b;
}
