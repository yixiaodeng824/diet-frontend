/* pages/analysis/analysis.wxss */
.container {
  padding: 40rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.upload-section {
  text-align: center;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.image-upload {
  width: 300rpx;
  height: 300rpx;
  border: 2rpx dashed #ddd;
  border-radius: 16rpx;
  margin: 0 auto 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: white;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.upload-placeholder {
  text-align: center;
}

.upload-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
}

.upload-btn {
  width: 200rpx;
  background: #07c160;
  color: white;
}

.result-section {
  margin-top: 40rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.result-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
}

.result-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.label {
  font-size: 24rpx;
  color: #666;
}

.value {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
}